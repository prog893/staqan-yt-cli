{
  "name": "staqan-yt-cli",
  "version": "1.1.0",
  "description": "A powerful CLI tool for managing YouTube videos and metadata using the YouTube Data API v3",
  "main": "dist/bin/staqan-yt.js",
  "bin": {
    "staqan-yt": "./dist/bin/staqan-yt.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bun": "bun build ./bin/staqan-yt.ts --compile --outfile staqan-yt",
    "build:bun:macos-arm64": "bun build ./bin/staqan-yt.ts --compile --target=bun-darwin-arm64 --outfile dist-bin/staqan-yt-macos-arm64",
    "build:bun:macos-x64": "bun build ./bin/staqan-yt.ts --compile --target=bun-darwin-x64 --outfile dist-bin/staqan-yt-macos-x64",
    "build:bun:all": "mkdir -p dist-bin && npm run build:bun:macos-arm64 && npm run build:bun:macos-x64",
    "package:tarballs": "mkdir -p release && tar -czf release/staqan-yt-macos-arm64.tar.gz -C dist-bin staqan-yt-macos-arm64 && tar -czf release/staqan-yt-macos-x64.tar.gz -C dist-bin staqan-yt-macos-x64",
    "release:prepare": "npm run build:bun:all && npm run package:tarballs",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsx bin/staqan-yt.ts",
    "prepublishOnly": "npm run build",
    "start": "node dist/bin/staqan-yt.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "youtube",
    "cli",
    "youtube-api",
    "video-management",
    "metadata"
  ],
  "author": "STAQAN",
  "license": "MIT",
  "dependencies": {
    "@googleapis/youtube": "^17.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^134.0.0",
    "open": "^8.4.2",
    "ora": "^5.4.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/commander": "^2.12.0",
    "@types/node": "^25.0.3",
    "@types/open": "^6.1.0",
    "@types/ora": "^3.1.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
