{
  "name": "staqan-yt-cli",
  "private": true,
  "version": "2.0.11",
  "description": "A powerful CLI tool for managing YouTube videos and metadata using the YouTube Data API v3",
  "main": "dist/bin/staqan-yt.js",
  "bin": {
    "staqan-yt": "./dist/bin/staqan-yt.js"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "bunx tsx bin/staqan-yt.ts",
    "prepublishOnly": "bun run build",
    "start": "bun run dist/bin/staqan-yt.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "preversion": "bun run scripts/preversion.ts",
    "version": "bun run scripts/version.ts",
    "postversion": "bun run scripts/postversion.ts"
  },
  "keywords": [
    "youtube",
    "cli",
    "youtube-api",
    "video-management",
    "metadata"
  ],
  "author": "STAQAN",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "google-auth-library": "10.5.0",
    "googleapis": "^173.0.0",
    "open": "^8.4.2",
    "ora": "^5.4.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/commander": "^2.12.0",
    "@types/node": "^25.0.3",
    "@types/open": "^6.1.0",
    "@types/ora": "^3.1.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
